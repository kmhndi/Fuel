{
  "expo": {
    "name": "Fuel",
    "slug": "fuel",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "fuel",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.khalidalmohannadi.fuel",
      "infoPlist": {
        "UIBackgroundModes": ["remote-notification"],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.khalidalmohannadi.fuel",
      "adaptiveIcon": {
        "backgroundColor": "#0B0E14"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "color": "#22D3A7"
        }
      ],
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "34cbca4c-405a-4d53-8bbd-4ecd09f08891"
      }
    }
  }
}
